{
  "name": "ltb-components",
  "version": "1.0.0",
  "description": "A React component library built on shadcn/ui with customizable AI chat widgets",
  "author": "LTB",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./chat": {
      "import": "./dist/chat.js",
      "types": "./dist/chat.d.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": "^0.400.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": false
    }
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "chat",
    "ai",
    "shadcn",
    "tailwind"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/magickhub/ltb-components",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/magickhub/ltb-components/issues"
  },
  "homepage": "https://github.com/magickhub/ltb-components#readme"
}
